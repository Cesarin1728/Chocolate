<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    android:networkSecurityConfig="@xml/network_security_config"
    xmlns:tools="http://schemas.android.com/tools">
    <!-- Añadimos esta parte nueva para el permiso -->
<!--    Le decimos que necesitamos usar el hardware del teléfono-->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

<!--    Declaramos el permiso, le decimos a android que se van a hacer llamadas-->
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:usesCleartextTraffic="true"
        android:allowBackup="true"
        android:dataExtractionRules="@xml/data_extraction_rules"
        android:fullBackupContent="@xml/backup_rules"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.Adopta">
        <activity
            android:name=".creador"
            android:exported="false" />
        <activity
            android:name=".contacto"
            android:exported="false" />
        <activity
            android:name=".activity_sesion"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity
            android:name=".eliminarmascota"
            android:exported="false" />
        <activity
            android:name=".guardarcambios"
            android:exported="false" />
        <activity
            android:name=".tarjeta"
            android:exported="false" />
        <activity
            android:name=".Ver"
            android:exported="false" />
        <activity
            android:name=".MainActivity"
            android:exported="false" />


    </application>

</manifest>