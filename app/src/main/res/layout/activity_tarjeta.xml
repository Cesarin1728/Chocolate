<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".tarjeta">

    <androidx.cardview.widget.CardView
        android:layout_width="350dp"
        android:layout_height="500dp"
        android:layout_gravity="center"
        app:cardElevation="15dp"
        app:cardCornerRadius="25dp"
        android:layout_marginTop="50dp">

        <ImageView
            android:layout_width="350dp"
            android:layout_height="500dp"
            android:src="@drawable/cohcolateimg"
            android:scaleType="centerCrop"
            android:alpha="0.3"
            android:contentDescription="Imagen de fondo" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvMarca"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Marca"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvPaisOrigen"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="País de Origen"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvTelefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Teléfono de Contacto"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvPresentacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Presentación"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvPorcentajeCacao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="% Cacao"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvTipoCacao"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tipo de Cacao"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvPerfilSabor"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Perfil del Sabor"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvTipo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tipo"
                android:textSize="15sp"
                android:layout_marginBottom="8dp" />

            <TextView
                android:id="@+id/tvPeso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Peso"
                android:textSize="15sp"
                android:layout_marginBottom="16dp" />


            <Button
                android:id="@+id/btnllamar"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Llamar"
                app:icon="@android:drawable/sym_action_call"
                app:iconTint = "#15cc0e"
                android:backgroundTint="#7B3F00"/>

            <Button
                android:id="@+id/btnVolver"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Volver"
                android:backgroundTint="#7B3F00"
                />

        </LinearLayout>

    </androidx.cardview.widget.CardView>



</LinearLayout>