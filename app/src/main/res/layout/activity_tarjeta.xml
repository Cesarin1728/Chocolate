<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="vertical"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".tarjeta">

    <androidx.cardview.widget.CardView
        android:layout_width="350dp"
        android:layout_height="500dp"
        android:layout_gravity="center"
        app:cardElevation="15dp"
        app:cardCornerRadius="25dp"
        android:layout_marginTop="50dp">

        <ImageView
            android:layout_width="350dp"
            android:layout_height="500dp"
            android:src="@drawable/cohcolateimg"
            android:scaleType="centerCrop"
            android:alpha="0.3"
            android:contentDescription="Imagen de fondo"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical"
            android:gravity="center_horizontal"
            android:padding="24dp">

            <TextView
                android:id="@+id/tvNombre"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Nombre"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvRaza"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Raza"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvAlimento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Alimento"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvTelefono"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Teléfono de Contacto"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvEspecie"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Especie"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvEdad"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Edad"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvTamaño"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Tamaño"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvPelaje"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Pelaje"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvComportamiento"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Comportamiento"
                android:textSize="15sp"
                android:layout_marginBottom="8dp"/>

            <TextView
                android:id="@+id/tvPeso"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Peso"
                android:textSize="15sp"
                android:layout_marginBottom="16dp"/>

            <Button
                android:id="@+id/btnllamar"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="Llamar"
                app:icon="@android:drawable/sym_action_call"
                app:iconTint="#15cc0e"
                android:backgroundTint="#00A9FF"/>
        </LinearLayout>

    </androidx.cardview.widget.CardView>

    <Button
        android:id="@+id/btnVolver"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:text="Volver"
        android:layout_marginTop="25dp"
        android:layout_gravity="center"
        android:backgroundTint="#00A9FF"
        />

</LinearLayout>
